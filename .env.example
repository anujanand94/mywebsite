# Copy this file to .env (never commit .env)
# These values are referenced in index.html as plain text placeholders —
# replace the HERO_VIDEO_URL string directly in index.html before deploying.

# Public URL of your hero video (Cloudflare R2, AWS S3, or any CDN)
# Example: https://pub-abc123.r2.dev/hero.mp4
HERO_VIDEO_URL=https://your-r2-bucket.r2.dev/hero.mp4

# The live URL of your portfolio (used for og:url / canonical if you add them later)
SITE_URL=https://yourdomain.com
